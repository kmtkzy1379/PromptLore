<%= form_with(model: preset, multipart: true, data: { turbo: false }) do |f| %>
  <% if preset.errors.any? %>
    <div>
      <h2><%= pluralize(preset.errors.count, "error") %> prohibited this preset from being saved:</h2>
      <ul>
        <% preset.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= hidden_field_tag :type, @form_type %>

  <div>
    <p><%= f.label :name, @form_type == "preset" ? "Preset Name" : "Skills Name" %></p>
    <p><%= f.text_field :name %></p>
  </div>

  <div>
    <p><%= f.label :description, "Description" %></p>
    <p><%= f.text_area :description, rows: 5 %></p>
  </div>

  <div>
    <p><%= f.label :visibility %></p>
    <p><%= f.select :visibility, Preset.visibilities.keys.map { |v| [v == "public_preset" ? "Public" : "Private", v] } %></p>
  </div>

  <% if current_user&.admin? %>
    <div>
      <label>
        <%= f.check_box :official %>
        Mark as Official
      </label>
    </div>
  <% end %>

  <% if @form_type == "preset" %>
    <fieldset>
      <legend>CLAUDE.md を含める</legend>
      <% if @user_repositories.any? %>
        <% selected_repo_ids = preset.persisted? ? preset.preset_repositories.pluck(:repository_id) : [] %>
        <% @user_repositories.each do |repo| %>
          <label style="display: block; margin: 3px 0;">
            <%= check_box_tag "repository_ids[]", repo.id, selected_repo_ids.include?(repo.id) %>
            <%= repo.name %>
          </label>
        <% end %>
      <% else %>
        <p><em>CLAUDE.md がまだありません。<%= link_to "CLAUDE.md をアップロード", new_repository_path %>してからここで選択できます。</em></p>
      <% end %>
    </fieldset>
  <% end %>

  <fieldset data-controller="file-upload">
    <legend><%= @form_type == "preset" ? "Skills ファイル" : "Skills フォルダをアップロード" %></legend>

    <% if @form_type == "skill" %>
      <p style="color: #666; font-size: 0.85em; margin: 0 0 10px;">
        スキルフォルダ（SKILL.md を含むフォルダ）をアップロードしてください。<br>
        ディレクトリ構造が自動で保持されます。
      </p>
    <% else %>
      <p style="color: #666; font-size: 0.85em; margin: 0 0 10px;">
        .md ファイルや、スキルフォルダ（SKILL.md を含むフォルダ）をアップロードできます。<br>
        フォルダの場合、ディレクトリ構造が自動で保持されます。
      </p>
    <% end %>

    <%# File inputs with name attributes so they're submitted %>
    <input type="file" multiple name="upload_files[]"
           data-file-upload-target="fileInput"
           data-action="change->file-upload#onFilesSelected"
           style="display: none;">
    <input type="file" webkitdirectory multiple name="folder_files[]"
           data-file-upload-target="folderInput"
           data-action="change->file-upload#onFolderSelected"
           style="display: none;">
    <input type="hidden" name="folder_paths"
           data-file-upload-target="pathsField" value="">

    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
      <% if @form_type == "preset" %>
        <button type="button" data-action="click->file-upload#selectFiles"
                style="padding: 8px 16px; cursor: pointer; border: 1px solid #0969da; background: #fff; color: #0969da; border-radius: 4px;">
          ファイルを選択
        </button>
      <% end %>
      <button type="button" data-action="click->file-upload#selectFolder"
              style="padding: 8px 16px; cursor: pointer; border: 1px solid #2da44e; background: #fff; color: #2da44e; border-radius: 4px;">
        フォルダを選択
      </button>
    </div>

    <%# Preview area %>
    <div data-file-upload-target="preview" style="margin-top: 10px;"></div>

    <%# Edit mode: show existing files %>
    <% if preset.persisted? %>
      <% existing_items = preset.preset_items.select { |i| i.persisted? && i.file.attached? } %>
      <% if existing_items.any? %>
        <div style="margin-top: 10px;">
          <p style="color: #555; font-size: 0.9em;"><strong>Current files:</strong></p>
          <%= f.fields_for :preset_items do |item_f| %>
            <% next unless item_f.object.persisted? && item_f.object.file.attached? %>
            <div style="border: 1px solid #eee; padding: 6px 8px; margin: 3px 0; display: flex; align-items: center; gap: 8px;">
              <code style="font-size: 0.85em;"><%= item_f.object.skill_relative_path %></code>
              <%= item_f.hidden_field :subdirectory %>
              <%= item_f.hidden_field :position %>
              <label style="margin-left: auto; font-size: 0.85em;">
                <%= item_f.check_box :_destroy %> Remove
              </label>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </fieldset>

  <div>
    <p><label>Categories</label></p>
    <% @categories.each do |category| %>
      <label>
        <%= check_box_tag "preset[category_ids][]", category.id, preset.category_ids.include?(category.id) %>
        <%= category.name %>
      </label>
    <% end %>
  </div>

  <div>
    <p><label for="tag_names">Tags (comma separated)</label></p>
    <p><%= text_field_tag :tag_names, preset.tags.pluck(:name).join(", "), placeholder: "e.g. rails, api, testing" %></p>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>
