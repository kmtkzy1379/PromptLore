<h1>All Presets</h1>

<%= form_tag presets_path, method: :get do %>
  <div>
    <%= text_field_tag :q, params[:q], placeholder: "Search presets..." %>
    <%= select_tag :category_id, options_for_select([["All categories", ""]] + Category.pluck(:name, :id), params[:category_id]) %>
    <%= text_field_tag :tag, params[:tag], placeholder: "Tag search..." %>
    <%= select_tag :sort, options_for_select([["Newest", "newest"], ["Oldest", "oldest"], ["Popular", "popular"], ["Trending", "trending"]], params[:sort]) %>
    <label>
      <%= check_box_tag :official, "true", params[:official] == "true" %>
      Official only
    </label>
    <%= submit_tag "Search" %>
  </div>
<% end %>

<hr>

<% if @presets.any? %>
  <% @presets.each do |preset| %>
    <div style="border: 1px solid #ccc; padding: 10px; margin: 10px 0;">
      <h3>
        <%= link_to preset.name, preset_path(preset) %>
        <% if preset.official? %>
          <span style="background: #28a745; color: #fff; padding: 2px 6px; border-radius: 3px; font-size: 12px;">Official</span>
        <% end %>
      </h3>
      <p>
        <strong>By:</strong> <%= link_to preset.user.username, user_path(preset.user) %> |
        <strong>Likes:</strong> <%= preset.likes_count %> |
        <strong>Downloads:</strong> <%= preset.downloads_count %>
      </p>
      <p><%= truncate(preset.description, length: 150) %></p>
      <% if preset.categories.any? %>
        <p><strong>Categories:</strong> <%= preset.categories.pluck(:name).join(", ") %></p>
      <% end %>
      <% if preset.tags.any? %>
        <p><strong>Tags:</strong> <%= preset.tags.pluck(:name).join(", ") %></p>
      <% end %>
    </div>
  <% end %>

  <%== @pagy.series_nav %>
<% else %>
  <p>No presets found.</p>
<% end %>
