<h1>
  <%= @repository.name %>
  <% if @repository.official? %>
    <span style="background: #28a745; color: #fff; padding: 2px 8px; border-radius: 3px; font-size: 14px;">Official</span>
  <% end %>
</h1>

<p>
  <strong>Type:</strong> CLAUDE.md |
  <strong>Visibility:</strong> <%= @repository.public_repo? ? "Public" : "Private" %> |
  <strong>By:</strong> <%= link_to @repository.user.username, user_path(@repository.user) %> |
  <strong>Likes:</strong> <%= @repository.likes_count %> |
  <strong>Downloads:</strong> <%= @repository.downloads_count %> |
  <strong>Created:</strong> <%= @repository.created_at.strftime("%Y-%m-%d") %>
</p>

<% if @repository.categories.any? %>
  <p><strong>Categories:</strong> <%= @repository.categories.pluck(:name).join(", ") %></p>
<% end %>

<% if @repository.tags.any? %>
  <p><strong>Tags:</strong> <%= @repository.tags.pluck(:name).join(", ") %></p>
<% end %>

<% if @repository.description.present? %>
  <h3>Description</h3>
  <p><%= simple_format(@repository.description) %></p>
<% end %>

<% if @repository.file.attached? %>
  <details style="border: 1px solid #ddd; padding: 8px; margin: 5px 0;">
    <summary>
      <strong><%= @repository.file.filename %></strong>
      &mdash;
      <%= link_to "Download", download_repository_path(@repository) %>
    </summary>
    <div class="markdown-body" style="margin-top: 10px;">
      <%= render_markdown(@repository.file.download.encode("UTF-8", "UTF-8", invalid: :replace, undef: :replace, replace: "?")) %>
    </div>
  </details>

  <%= render "shared/install_actions",
       raw_content_url: raw_content_repository_path(@repository),
       resource_type: "repository" %>
<% end %>

<% if user_signed_in? %>
  <p>
    <% if @repository.liked_by?(current_user) %>
      <%= button_to "Unlike", toggle_like_repository_path(@repository), method: :post %>
    <% else %>
      <%= button_to "Like", toggle_like_repository_path(@repository), method: :post %>
    <% end %>
  </p>
<% end %>

<% if user_signed_in? && @repository.user == current_user %>
  <%= render "shared/version_history",
       versions: @repository.versions.order(version_number: :desc),
       restore_path: ->(opts) { restore_repository_path(@repository, **opts) },
       toggle_pin_path: ->(opts) { toggle_pin_repository_path(@repository, **opts) },
       update_memo_path: ->(opts) { update_memo_repository_path(@repository, **opts) },
       preview_path: ->(opts) { preview_version_repository_path(@repository, **opts) } %>

  <p>
    <%= link_to "Edit", edit_repository_path(@repository) %> |
    <%= form_with(url: repository_path(@repository), method: :delete, style: "display: inline") do |f| %>
      <%= f.password_field :password, placeholder: "Enter password to delete" %>
      <%= f.submit "Delete", data: { turbo_confirm: "Are you sure?" } %>
    <% end %>
  </p>
<% end %>

<%= link_to "Back", root_path %>
