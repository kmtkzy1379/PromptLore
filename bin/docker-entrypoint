#!/bin/bash -e

# If running the rails server then create or migrate existing database
should_prepare=false
prev=""
for arg in "$@"; do
  if [ "$prev" = "./bin/rails" ] && [ "$arg" = "server" ]; then
    should_prepare=true
    break
  fi
  prev="$arg"
done

if [ "$should_prepare" = true ]; then
  ./bin/rails db:prepare
fi

exec "$@"
